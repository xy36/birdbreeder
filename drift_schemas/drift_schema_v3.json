  "fixed_sql": [
    {
      "name": "birds",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"birds\" (\"id\" TEXT NOT NULL, \"ringnumber\" TEXT NULL, \"species\" TEXT NULL, \"color\" TEXT NULL, \"sex\" TEXT NOT NULL DEFAULT 'unknown', \"father\" TEXT NULL, \"mother\" TEXT NULL, \"cage\" TEXT NULL, \"brood\" TEXT NULL, \"laid_at\" INTEGER NULL, \"hatched_at\" INTEGER NULL, \"fledged_at\" INTEGER NULL, \"born_at\" INTEGER NULL, \"died_at\" INTEGER NULL, \"sale_status\" TEXT NOT NULL DEFAULT 'notForSale', \"listed_at\" INTEGER NULL, \"sold_at\" INTEGER NULL, \"asking_price\" REAL NULL, \"final_price\" REAL NULL, \"bought_at\" INTEGER NULL, \"bought_price\" REAL NULL, \"notes\" TEXT NULL, \"bought_from\" TEXT NULL, \"sold_to\" TEXT NULL, \"owner\" TEXT NULL, \"breeder\" TEXT NULL, \"unknown_lifecycle\" INTEGER NULL CHECK (\"unknown_lifecycle\" IN (0, 1)), \"user\" TEXT NULL, \"created\" INTEGER NULL, \"updated\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "breeding_pairs",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"breeding_pairs\" (\"id\" TEXT NOT NULL, \"father\" TEXT NOT NULL, \"mother\" TEXT NOT NULL, \"status\" TEXT NOT NULL, \"cage\" TEXT NULL, \"start\" INTEGER NULL, \"end\" INTEGER NULL, \"notes\" TEXT NULL, \"user\" TEXT NULL, \"created\" INTEGER NULL, \"updated\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "broods",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"broods\" (\"id\" TEXT NOT NULL, \"breeding_pair\" TEXT NULL, \"cage\" TEXT NULL, \"start\" INTEGER NULL, \"end\" INTEGER NULL, \"notes\" TEXT NULL, \"user\" TEXT NULL, \"created\" INTEGER NULL, \"updated\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "eggs",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"eggs\" (\"id\" TEXT NOT NULL, \"brood\" TEXT NOT NULL, \"number\" INTEGER NOT NULL, \"laid_at\" INTEGER NOT NULL, \"hatched_at\" INTEGER NULL, \"fertilized_at\" INTEGER NULL, \"unfertilized_at\" INTEGER NULL, \"fledged_at\" INTEGER NULL, \"died_at\" INTEGER NULL, \"status\" TEXT NOT NULL DEFAULT 'laid', \"ringnumber\" TEXT NULL, \"color\" TEXT NULL, \"cage\" TEXT NULL, \"species\" TEXT NULL, \"bird_id\" TEXT NULL, \"notes\" TEXT NULL, \"created\" INTEGER NULL, \"updated\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "contacts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"contacts\" (\"id\" TEXT NOT NULL, \"number\" TEXT NULL, \"phone\" TEXT NULL, \"cell_phone_number\" TEXT NULL, \"title\" TEXT NULL, \"first_name\" TEXT NULL, \"last_name\" TEXT NULL, \"email\" TEXT NULL, \"address\" TEXT NULL, \"city\" TEXT NULL, \"country\" TEXT NULL, \"postal_code\" TEXT NULL, \"website\" TEXT NULL, \"is_app_user\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_app_user\" IN (0, 1)), \"user\" TEXT NULL, \"created\" INTEGER NULL, \"updated\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
